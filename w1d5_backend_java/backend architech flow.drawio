        <mxCell id="pGQkyeDspjTqNUi92ogL-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="Database" vertex="1">
          <mxGeometry height="60" width="120" x="600" y="540" as="geometry" />
